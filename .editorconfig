# EditorConfig is awesome: http://EditorConfig.org

root = true

[*]
end_of_line = lf
111
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.md]
indent_style = space
indent_size = 4

[*.xml]
indent_style = space
indent_size = 4
